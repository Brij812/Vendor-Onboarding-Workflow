# PostgreSQL (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendor_onboarding
DB_USER=vendor_app
DB_PASSWORD=vendor_app_secret

# Backend
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:5173
UPLOADS_DIR=./uploads
WORKFLOW_STEP_DELAY_MS=800

# Demo utilities (dev only)
DEMO_ENDPOINTS_ENABLED=true

# Optional LLM integration (OpenAI-compatible)
# When omitted, communication, audit summary, and structured document extraction use template/rule fallbacks.
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com
LLM_TIMEOUT_MS=30000
